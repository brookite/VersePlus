{
	"schemaVersion": 1,
	"id": "verseplus",
	"version": "${version}",
	"name": "VersePlus",
	"description": "Minecraft Vanilla Enhancement Mod for Fabric",
	"authors": [
		"brookit"
	],
    "accessWidener" : "verseplus.classtweaker",
	"contact": {
		"homepage": "https://github.com/brookite/VersePlus",
		"sources": "https://github.com/brookite/VersePlus"
	},
	"license": "Apache-2.0",
	"icon": "assets/verseplus/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
          "io.github.brookite.verseplus.VersePlus"
		],
        "client": [
          "io.github.brookite.verseplus.VersePlusClient"
        ],
		"fabric-datagen": [
          "io.github.brookite.verseplus.VersePlusDataGenerator"
		]
	},
	"mixins": [
		"verseplus.mixins.json"
	],
	"depends": {
		"fabricloader": ">=0.19.3",
		"minecraft": "${minecraft_version}",
		"java": ">=25",
		"fabric-api": "*"
	},
	"suggests": {
		"another-mod": "*"
	}
}
